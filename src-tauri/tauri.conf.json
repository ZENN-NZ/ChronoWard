{
  "productName": "ChronoWard",
  "version": "1.1.1",
  "identifier": "com.chronoward.desktop",

  "build": {
    "frontendDist": "../src"
  },

  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data:; connect-src 'none'; frame-src 'none'; object-src 'none'"
    },
    "windows": [
      {
        "label": "main",
        "title": "ChronoWard - Protect your time, meet your goals",
        "width": 1200,
        "height": 750,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "visible": false,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "center": true,
        "url": "index.html"
      },
      {
        "label": "overlay",
        "title": "",
        "width": 64,
        "height": 64,
        "minWidth": 64,
        "minHeight": 64,
        "resizable": false,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "url": "overlay.html"
      }
    ]
  },

  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "icons/icon.png"
    ],
    "externalBin": [],
    "copyright": "© 2026 Jeremiah Benjamin",
    "category": "Productivity",
    "shortDescription": "Protect your time, meet your goals",
    "longDescription": "A secure, fully offline timesheet application for focused work logging.",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": false
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "displayLanguageSelector": false,
        "languages": ["English"]
      }
    }
  }
}